# Instagram Graph API credentials (optional)
# 設定しない場合、ギャラリーはJSONの手動ピックアップのみで表示されます。
#
# 1) Facebook Developers でアプリを作成し、Instagram Graph API を有効化
# 2) Instagram ビジネス/クリエイターアカウントを Facebook ページと紐付け
# 3) 長期アクセストークン（ig_hashtag_search, pages_read_engagement など）を発行
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# 取得したいハッシュタグ（# は不要、日本語OK）
INSTAGRAM_HASHTAG=3dひろば
