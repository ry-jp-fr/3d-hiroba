# Meta App credentials for Instagram oEmbed API
# 設定しない場合、管理画面でのInstagram投稿自動取得が無効になります
#
# 1) https://developers.facebook.com でアプリを作成
# 2) "Instagram Graph API" を有効化
# 3) アプリロールで "App ID" と "App Secret" を取得
# 4) 以下に設定して、BLOB_READ_WRITE_TOKEN も設定します
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# 管理画面（/admin）のパスワード
# 設定すると /admin 配下でログインが必要になります。未設定ならノーガードです。
ADMIN_PASSWORD=

# Vercel Cron (weekly Instagram og:image refresh)
# Used by /api/cron/refresh-thumbnails. Set to a random string and add it as
# a Vercel environment variable; Vercel Cron sends "Authorization: Bearer <secret>".
CRON_SECRET=
